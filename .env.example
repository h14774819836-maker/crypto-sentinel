APP_ENV=dev
# Admin auth token for management APIs (required, all admin endpoints locked if empty)
ADMIN_TOKEN=change-me-to-a-strong-secret
LOG_LEVEL=INFO
MARKET_AI_LOG_LEVEL=INFO
MARKET_AI_LOG_VERBOSE=false
# AI 流式分析超时(秒)，大模型如 Kimi K2.5 建议 420+
MARKET_AI_STREAM_SYMBOL_TIMEOUT_SECONDS=420
APP_VERSION=0.2.0
TIMEZONE=UTC

DATABASE_URL=sqlite:///./data/crypto_sentinel.db
DB_ENFORCE_POSTGRES_ENVS=stage,prod
DB_DISABLE_FALLBACK_ENVS=stage,prod
DB_ALLOW_FALLBACK_CREATE_ALL=false

WATCHLIST=BTCUSDT

# Optional outbound proxy for Docker/local runtime.
# If Binance / external LLM APIs are blocked in your network, set these.
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1,db,redis

BINANCE_REST_URL=https://api.binance.com
BINANCE_WS_URL=wss://stream.binance.com:9443/stream
# Binance private USER_DATA (recommend read-only key + IP whitelist)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_RECV_WINDOW=5000
ENABLE_MINITICKER=false

POLL_SECONDS=10
KLINE_SYNC_SECONDS=60
GAP_FILL_INTERVAL_SECONDS=120
BACKFILL_DAYS_DEFAULT=7
WORKER_ROLE=all
WORKER_HEARTBEAT_SECONDS=15
WORKER_ID_STRICT_UNIQUE=true
# --- 账户监控（需 BINANCE_API_KEY/SECRET，建议只读权限） ---
# 是否启用账户监控：定时拉取合约/杠杆账户快照，低于阈值时发 Telegram 告警
ACCOUNT_MONITOR_ENABLED=false
# 监控轮询间隔（秒），默认 15 秒拉一次 Binance 账户
ACCOUNT_MONITOR_SECONDS=15
# 关注的交易对，用于持仓/强平价格等展示
ACCOUNT_WATCH_SYMBOL=BTCUSDT
# 可用余额告警阈值（USDT）：低于此值触发 ACCOUNT_AVAILABLE_BALANCE_LOW
ACCOUNT_ALERT_MIN_AVAILABLE_BALANCE=100
# 强平距离告警阈值（%）：标记价与强平价距离小于此百分比时触发 ACCOUNT_LIQUIDATION_RISK
ACCOUNT_ALERT_LIQ_DISTANCE_PCT=5
# 动态强平阈值 ATR 倍数：阈值%=ATR_MULTIPLIER*(ATR14/markPrice)*100
ACCOUNT_ALERT_LIQ_ATR_MULTIPLIER=1.5
# 动态阈值静态下限（%）：最终阈值=max(动态阈值, 静态下限)
ACCOUNT_ALERT_LIQ_STATIC_FLOOR_PCT=5
# 杠杆风险告警：margin_level 低于 margin_call_bar * (1 - 此值) 时触发
ACCOUNT_ALERT_MARGIN_LEVEL_BUFFER=0.2
ACCOUNT_USER_STREAM_ENABLED=false
ACCOUNT_USER_STREAM_KEEPALIVE_SECONDS=3000
ACCOUNT_MONITOR_WS_FALLBACK_SECONDS=60
ACCOUNT_SNAPSHOT_RETENTION_DAYS=14
# 快照差异化存储容差（关键标量绝对变化小于该值时视为无变化）
ACCOUNT_SNAPSHOT_CHANGE_TOLERANCE=0.0001
# 冷热分离：是否压缩写入原始 JSON 至 account_snapshot_raw
ACCOUNT_SNAPSHOT_RAW_ENABLED=true
# 是否在主快照表继续保留原始 JSON（建议 false，减小表体积）
ACCOUNT_SNAPSHOT_MAIN_STORE_RAW=false
# 冷表保留天数
ACCOUNT_SNAPSHOT_RAW_RETENTION_DAYS=30
# 日级权益曲线聚合（daily OHLC）
ACCOUNT_DAILY_STATS_ENABLED=true

# Feature incremental pipeline
FEATURE_INCREMENTAL_ENABLED=true
FEATURE_LOOKBACK_ROWS=180
FEATURE_MAX_PENDING_BARS=20
FEATURE_MAX_BATCHES_PER_RUN=3
FEATURE_TIMEFRAMES=1m,5m,10m,15m,1h,4h

# Ops/job metrics
OPS_JOB_METRICS_WINDOW=200
OPS_JOB_METRICS_FILE=data/job_metrics.json
OPS_JOB_METRICS_FILES_JSON=

# 同类型告警冷却时间（秒）：同一 symbol+alert_type 在此时间内不重复发送，默认 30 分钟
ALERT_COOLDOWN_SECONDS=1800
VOL_P75_MIN_CANDLES=10080
VOL_FALLBACK_MIN_CANDLES=200
VOL_FALLBACK_K=2.0

ANOMALY_ENGINE_MODE=score_v1
ANOMALY_VOLUME_ZSCORE_THRESHOLD=3.0
ANOMALY_SCORE_THRESHOLD_TRENDING=70
ANOMALY_SCORE_THRESHOLD_RANGING=85
ANOMALY_SCORE_THRESHOLD_VOLATILE=80
ANOMALY_SCORE_THRESHOLD_UNCONFIRMED_EXTREME=92
ANOMALY_PERSIST_ENTER_BARS=2
ANOMALY_HYSTERESIS_EXIT_DELTA=20
ANOMALY_REQUIRE_MTF_CONFIRM=true
ANOMALY_MTF_CONFIRM_TFS=5m,15m
ANOMALY_BUDGET_PER_SYMBOL_PER_DAY=5
ANOMALY_BUDGET_EXCESS_ACTION=store_only
ANOMALY_COOLDOWN_SECONDS_SCORE_80_84=1800
ANOMALY_COOLDOWN_SECONDS_SCORE_85_91=3600
ANOMALY_COOLDOWN_SECONDS_SCORE_92_PLUS=600
ANOMALY_FLASH_ENABLED=true
ANOMALY_FLASH_REQUIRE_MTF_CONFIRM=false
ANOMALY_AI_DIAGNOSTIC_ENABLED=true
ANOMALY_AI_DIAGNOSTIC_TIMEOUT_SECONDS=120
ANOMALY_AI_DIAGNOSTIC_BATCH_WINDOW_SECONDS=45
ANOMALY_AI_DIAGNOSTIC_LOOKBACK_MINUTES=5
ANOMALY_AI_DIAGNOSTIC_MAX_ALERTS=8
ANOMALY_ALERT_REF_ENABLED=true
ANOMALY_AI_INTEL_LOOKBACK_HOURS=4
ANOMALY_AI_YOUTUBE_LOOKBACK_HOURS=4
ANOMALY_TICK_FLASH_ENABLED=true
ANOMALY_TICK_FLASH_LOOKBACK_SECONDS=15
ANOMALY_TICK_FLASH_RET_THRESHOLD=0.0018
ANOMALY_TICK_FLASH_COOLDOWN_SECONDS=90
TELEGRAM_ALERT_TEMPLATE_STYLE=readable
TELEGRAM_ALERT_INCLUDE_DEBUG=false

# Dynamic anomaly thresholds
SPIKE_ATR_MULTIPLIER=1.5
SPIKE_FALLBACK_THRESHOLD=0.012
BREAKOUT_LOOKBACK=50

# --- Telegram 告警推送 ---
# 是否启用 Telegram 推送（账户风险、AI 信号、系统告警等）
TELEGRAM_ENABLED=false
# Bot Token：从 @BotFather 创建机器人后获得
TELEGRAM_BOT_TOKEN=
# 接收告警的 Chat ID：与机器人对话后，用 getUpdates 或 @userinfobot 获取
TELEGRAM_CHAT_ID=
TELEGRAM_INBOUND_MODE=polling
TELEGRAM_POLLING_TIMEOUT_SECONDS=50
TELEGRAM_POLLING_INTERVAL_SECONDS=0.2
TELEGRAM_POLLING_AUTO_DELETE_WEBHOOK=true
TELEGRAM_POLLING_DROP_PENDING_UPDATES=true
TELEGRAM_POLLING_STATE_FILE=data/telegram_poller_state.json

# --- LLM Providers (可同时配置，多任务分工) ---
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ARK_API_KEY=
# 副模型 thinking_summary 使用 nvidia_nim 时需配置
NVIDIA_NIM_API_KEY=

# --- LLM Profiles (JSON) ---
# profile 负责定义 provider/model/并发/重试等，可被多个任务复用
# provider 可选：deepseek / openrouter / openai_compatible / ark / nvidia_nim
# base_url_override / api_key_override 可按 profile 覆盖
LLM_PROFILES_JSON={"general":{"provider":"deepseek","model":"deepseek-chat","use_reasoning":"auto","enabled":true},"market":{"provider":"openrouter","model":"google/gemini-3.1-pro-preview","use_reasoning":"auto","enabled":true},"youtube":{"provider":"deepseek","model":"deepseek-chat","use_reasoning":"auto","enabled":true},"thinking_summary":{"provider":"nvidia_nim","model":"nvidia_nim/nemotron-3-nano-30b-a3b","use_reasoning":"false","enabled":true}}

# --- LLM Task Routing (JSON) ---
# 任务 -> profile 名称；telegram_chat 推荐走便宜模型，market 可走更强模型
LLM_TASK_ROUTING_JSON={"telegram_chat":"general","market":"market","youtube":"youtube","selfcheck":"general"}
LLM_HOT_RELOAD_SIGNAL_FILE=data/llm_hot_reload_signal.json
LLM_HOT_RELOAD_ACK_FILE=data/llm_hot_reload_ack.json
# Redis for LLM hot reload (multi-worker). Default: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0
# Use Redis Pub/Sub for LLM hot reload (default: true). Set false to fallback to file protocol (single-worker only)
LLM_HOT_RELOAD_USE_REDIS=true

AI_ANALYSIS_INTERVAL_SECONDS=600
AI_MANUAL_PREFLIGHT_MODE=legacy
AI_MANUAL_PREFLIGHT_STALE_SECONDS=300
AI_MANUAL_PREFLIGHT_LOCK_SECONDS=120
AI_SIGNAL_CONFIDENCE_THRESHOLD=70
AI_HISTORY_CANDLES=50
AI_TWO_STAGE_ENABLED=true
AI_SCAN_CONFIDENCE_THRESHOLD=60
AI_MIN_CONTEXT_ON_POOR_DATA=true
AI_MIN_CONTEXT_ON_NON_TRADEABLE=true
AI_EXTERNAL_VIEWS_ON_LOW_CONF_ONLY=true
# Thinking summary: 副模型提炼 reasoning 摘要（双流架构）。thinking_summary 用 nvidia_nim 时需配置 NVIDIA_NIM_API_KEY
AI_THINKING_SUMMARY_ENABLED=true
AI_THINKING_SUMMARY_MIN_CHARS=300
AI_THINKING_SUMMARY_INTERVAL_SEC=3.0
AI_THINKING_SUMMARY_MAX_STREAMING=15
AI_THINKING_SUMMARY_PROFILE=thinking_summary
# Telegram 对话副模型阶段反馈（主模型思考时动态更新状态消息）
AI_TELEGRAM_THINKING_SUMMARY_ENABLED=true
AI_TELEGRAM_THINKING_SUMMARY_MAX_STREAMING=10

# Multi-timeframe
MULTI_TF_INTERVALS=5m,15m,1h,4h
MULTI_TF_SYNC_SECONDS=300
MULTI_TF_BACKFILL_DAYS=30

# Binance Futures (funding rate + open interest)
BINANCE_FUTURES_URL=https://fapi.binance.com
FUNDING_RATE_SYNC_SECONDS=300

# Intel / News
INTEL_ENABLED=false
INTEL_POLL_SECONDS=900
INTEL_DIGEST_POLL_SECONDS=300
INTEL_MAX_ITEMS_PER_RUN=200
INTEL_DIGEST_LOOKBACK_HOURS=24

# YouTube 观点追踪（默认关闭）
YOUTUBE_ENABLED=false
YOUTUBE_CHANNEL_IDS=
YOUTUBE_POLL_SECONDS=1800
YOUTUBE_MAX_VIDEOS_PER_RUN=10
# 可选拆分（留空则回退到上面两个配置）
YOUTUBE_ANALYZE_POLL_SECONDS=180
YOUTUBE_ASR_BACKFILL_SECONDS=600
YOUTUBE_ANALYZE_MAX_PER_RUN=5
YOUTUBE_SUBTITLE_FETCH_MAX_PER_RUN=10
YOUTUBE_LANGS=zh-Hans,zh-Hant,en
YOUTUBE_CONSENSUS_LOOKBACK_HOURS=48
YOUTUBE_TARGET_SYMBOL=BTCUSDT
YOUTUBE_ANALYSIS_STALL_RUNNING_SECONDS=420
YOUTUBE_AUTH_AUTO_RECOVER_ENABLED=true
YOUTUBE_AUTH_AUTO_RECOVER_BATCH=20
YOUTUBE_AUTH_AUTO_RECOVER_MAX_ATTEMPTS=2

# ASR 本地转录（默认关闭，需 GPU 推荐）
ASR_ENABLED=false
ASR_BACKEND=local_faster_whisper
ASR_MODEL=small
ASR_DEVICE=cuda
ASR_COMPUTE_TYPE=float16
ASR_VAD_FILTER=true
ASR_MAX_VIDEOS_PER_RUN=3
ASR_AUDIO_CACHE_DIR=data/audio
ASR_KEEP_AUDIO=false
ASR_MAX_CONCURRENT=2
